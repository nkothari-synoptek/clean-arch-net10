{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  
  "AzureAd": {
    "Authority": "https://login.microsoftonline.com/{tenant-id}",
    "ClientId": "{client-id}",
    "TenantId": "{tenant-id}"
  },
  
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/apigateway-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  
  "ReverseProxy": {
    "Routes": {
      "inspection-create-route": {
        "ClusterId": "inspection-cluster",
        "AuthorizationPolicy": "CanCreateInspection",
        "Match": {
          "Path": "/api/inspections",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/inspections"
          }
        ]
      },
      "inspection-update-route": {
        "ClusterId": "inspection-cluster",
        "AuthorizationPolicy": "CanCreateInspection",
        "Match": {
          "Path": "/api/inspections/{id}",
          "Methods": [ "PUT" ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/inspections/{id}"
          }
        ]
      },
      "inspection-delete-route": {
        "ClusterId": "inspection-cluster",
        "AuthorizationPolicy": "CanCreateInspection",
        "Match": {
          "Path": "/api/inspections/{id}",
          "Methods": [ "DELETE" ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/inspections/{id}"
          }
        ]
      },
      "inspection-get-route": {
        "ClusterId": "inspection-cluster",
        "Match": {
          "Path": "/api/inspections/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/inspections/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "inspection-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://inspection-service:80"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}
