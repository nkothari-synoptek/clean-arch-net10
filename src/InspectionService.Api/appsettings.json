{
  "AzureKeyVault": {
    "Enabled": false,
    "VaultUri": "",
    "ManagedIdentityClientId": "",
    "ReloadEnabled": false,
    "ReloadInterval": "00:05:00"
  },
  "ServiceSecrets": {
    "Database": {
      "ConnectionString": ""
    },
    "Cache": {
      "RedisConnectionString": ""
    },
    "Messaging": {
      "ServiceBusConnectionString": "",
      "ServiceBusFullyQualifiedNamespace": ""
    }
  },
  "AzureEntraId": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "your-tenant-id",
    "ClientId": "your-client-id",
    "Audience": "api://your-api-id"
  },
  "OpenTelemetry": {
    "ServiceName": "InspectionService",
    "ServiceVersion": "1.0.0",
    "AzureMonitor": {
      "ConnectionString": "InstrumentationKey=your-instrumentation-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/inspection-service-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
